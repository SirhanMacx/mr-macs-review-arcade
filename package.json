{
  "name": "mr-macs-review-arcade",
  "version": "6.11.0",
  "private": true,
  "description": "Mr. Mac's Review Arcade — standards-aligned 5-12/AP review arcade with trivia, Jeopardy, and practice-exam systems.",
  "homepage": "https://sirhanmacx.github.io/mr-macs-review-arcade/",
  "scripts": {
    "test": "playwright test",
    "smoke": "playwright test --reporter=list",
    "perf:budget": "node scripts/performance-budget.mjs",
    "bank": "node scripts/build-shared-question-bank.mjs",
    "content:all-subjects": "node scripts/generate-all-subject-content.mjs && node scripts/build-shared-question-bank.mjs",
    "validate:content": "node scripts/validate-all-subject-content.mjs",
    "serve": "python3 -m http.server 8090"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0"
  }
}
